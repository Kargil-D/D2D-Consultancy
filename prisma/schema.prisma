// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Admin enums
enum Status {
  Active
  Inactive
}

enum OtpPurpose {
  Registration
  ForgotPassword
}

model Role {
  id   String @id @default(uuid())
  name String @unique // Admin | Employee | Customer

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model User {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  email           String    @unique
  phoneNumber     String?
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(false)
  lastLogin       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailOtps             EmailOtp[]
  refreshTokens         RefreshToken[]
  assignedLeads         Lead[]
  bookingsAsExecutive   Booking[]      @relation("BookingExecutive")
  bookingsAsSupport     Booking[]      @relation("CustomerSupport")
  quotationsAsSalesExec Quotation[]    @relation("QuotationSalesExecutive")

  @@index([roleId])
  @@map("users")
}

model EmailOtp {
  id        String     @id @default(uuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  email     String
  otpHash   String
  purpose   OtpPurpose
  attempts  Int        @default(0)
  expiresAt DateTime
  isUsed    Boolean    @default(false)

  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("email_otps")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Destination {
  id              String   @id @default(uuid())
  name            String
  country         String
  state           String?
  city            String?
  slug            String   @unique
  shortDescription String
  fullDescription String
  thumbnailImage  String?
  bannerImage     String?
  isPopular       Boolean  @default(false)
  displayOrder    Int      @default(0)
  seoTitle        String?
  seoDescription  String?
  status          Status   @default(Active)
  isDomestic      Boolean  @default(false)

  // Audit
  createdBy       String?
  createdDate     DateTime @default(now())
  updatedBy       String?
  updatedDate     DateTime @updatedAt
  isDeleted       Boolean  @default(false)

  campaigns       Campaign[]
  leads           Lead[]
  quotations      Quotation[]
  bookings        Booking[]
  hotelMasters    HotelMaster[]

  @@map("destinations")
}

model Campaign {
  id                  String      @id @default(uuid())
  name                String
  destinationId       String
  destination         Destination @relation(fields: [destinationId], references: [id], onDelete: Restrict)
  packageType         String      @default("Standard")
  days                Int         @default(0)
  nights              Int         @default(0)
  startingPrice       Int         @default(0)
  offerPrice          Int?
  thumbnail           String?
  coverBanner         String?
  shortDescription    String      @default("")
  highlights          String[]    @default([])
  inclusions          String[]    @default([])
  exclusions          String[]    @default([])
  bestTimeToVisit     String?
  travelTypes         String[]    @default([])
  isFeatured          Boolean     @default(false)
  isRecentlyViewed    Boolean     @default(false)
  isHeroCampaign      Boolean     @default(false)
  viewDetailsRedirect String?
  slug                String      @unique
  seoTitle            String?
  seoDescription      String?
  status              Status      @default(Active)
  gallery             String[]    @default([])
  bookedByName        String?
  bookedByCity        String?
  bookedByAgo         String?
  activities          Json        @default("[]")
  inclusionsText      String      @default("")
  exclusionsText      String      @default("")
  packageCost         Int         @default(0)
  platformFee         Int         @default(0)
  gstPercent          Float       @default(5)
  marginPrice         Int         @default(0)
  insurancePrice      Int         @default(0)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  itineraries Itinerary[]
  hotels      Hotel[]
  transfers   Transfer[]
  quotations  Quotation[]

  @@index([destinationId])
  @@map("campaigns")
}

model Itinerary {
  id                 String   @id @default(uuid())
  packageId          String
  campaign           Campaign @relation(fields: [packageId], references: [id], onDelete: Cascade)
  title              String   @default("")
  overview           String   @default("")
  totalDays          Int      @default(0)
  days               Json     @default("[]")
  packageIncludes    String[] @default([])
  packageExcludes    String[] @default([])
  termsAndConditions String   @default("")
  cancellationPolicy String   @default("")
  faqs               Json     @default("[]")
  galleryImages      String[] @default([])
  mapLocation        String?
  customerNotes      String?
  ctaButtonText      String   @default("Send Enquiry")
  ctaRedirect        String   @default("/plan-trip")
  status             Status   @default(Active)
  isPublished        Boolean  @default(false)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([packageId])
  @@map("itineraries")
}

model Hotel {
  id        String   @id @default(uuid())
  packageId String
  campaign  Campaign @relation(fields: [packageId], references: [id], onDelete: Cascade)
  hotels    Json     @default("[]")
  status    Status   @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([packageId])
  @@map("hotels")
}

model Transfer {
  id        String   @id @default(uuid())
  packageId String
  campaign  Campaign @relation(fields: [packageId], references: [id], onDelete: Cascade)
  transfers Json     @default("[]")
  status    Status   @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([packageId])
  @@map("transfers")
}

model TransferType {
  id     String @id @default(uuid())
  name   String
  status Status @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@map("transfer_types")
}

model HotelMaster {
  id            String       @id @default(uuid())
  name          String
  destinationId String?
  destination   Destination? @relation(fields: [destinationId], references: [id])
  images        String[]     @default([])
  description   String       @default("")
  category      String?
  roomTypes     String[]     @default([])
  mealPlans     String[]     @default([])
  amenities     String[]     @default([])
  googleMapUrl  String?
  website       String?
  status        Status       @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([destinationId])
  @@map("hotel_master")
}

enum LeadSource {
  Website
  MetaAds
  GoogleAds
  SEO
  WhatsApp
  Referral
  Manual
}

enum LeadStatus {
  New
  Contacted
  FollowUp
  QuotationSent
  PaymentPending
  Won
  Lost
}

model Lead {
  id            String      @id @default(uuid())
  seq           Int         @unique @default(autoincrement())
  customerName  String
  mobile        String
  email         String?
  companyName   String?
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id])
  travelDate    DateTime?
  source        LeadSource
  adults        Int?
  children      Int?
  assignedToId  String?
  assignedTo    User?       @relation(fields: [assignedToId], references: [id])
  remarks       String?
  status        LeadStatus  @default(New)

  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  activities  LeadActivity[]
  quotations  Quotation[]
  bookings    Booking[]

  @@index([destinationId])
  @@index([assignedToId])
  @@map("leads")
}

model LeadActivity {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  message     String
  createdDate DateTime @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

enum QuotationStatus {
  Draft
  Sent
  Accepted
  Rejected
  Expired
}

enum QuotationComponent {
  Hotel
  Transfer
  Activity
  Visa
  Insurance
  Flight
}

model Quotation {
  id            String          @id @default(uuid())
  seq           Int             @unique @default(autoincrement())
  leadId        String
  lead          Lead            @relation(fields: [leadId], references: [id])
  destinationId String
  destination   Destination     @relation(fields: [destinationId], references: [id])
  campaignId    String?
  campaign      Campaign?       @relation(fields: [campaignId], references: [id])
  marginPercent Float           @default(0)
  status        QuotationStatus @default(Draft)
  shareToken    String?         @unique

  // Step 1 — Trip & Traveller Details (quotation-specific, independent of the linked Lead's own values)
  travelDate DateTime?
  days       Int?
  nights     Int?
  adults     Int  @default(1)
  children   Int  @default(0)
  infants    Int  @default(0)

  // Step 1 — Other Details
  salesExecutiveId String?
  salesExecutive   User?      @relation("QuotationSalesExecutive", fields: [salesExecutiveId], references: [id])
  source           LeadSource?
  validUntil       DateTime?
  internalNotes    String?

  // Steps 2–5 — Itinerary / Hotels / Transfers / Activities (manual entry, JSON — same pattern as Campaign.activities / Itinerary.days)
  itineraryMode String @default("custom")
  itineraryDays Json   @default("[]")
  hotelOptions  Json   @default("[]")
  transfers     Json   @default("[]")
  activities    Json   @default("[]")

  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  items    QuotationItem[]
  bookings Booking[]

  @@index([leadId])
  @@index([destinationId])
  @@map("quotations")
}

model QuotationItem {
  id            String             @id @default(uuid())
  quotationId   String
  quotation     Quotation          @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  component     QuotationComponent
  /** Links this costing row back to its source hotel/activity/transfer id (from the Quotation's JSON content fields) so Pricing stays in sync as those are added/edited/removed. Null for manually-added rows (Visa/Insurance/Flight). */
  sourceId      String?
  detail        String             @default("")
  qty           Int                @default(1)
  cost          Int                @default(0)
  currencyCode  String             @default("INR")
  foreignAmount Float?
  exchangeRate  Float              @default(1)
  sortOrder     Int                @default(0)

  @@index([quotationId])
  @@map("quotation_items")
}

model Currency {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  exchangeRate  Float
  effectiveFrom DateTime
  status        Status   @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  rateHistory CurrencyRateHistory[]

  @@map("currencies")
}

model CurrencyRateHistory {
  id            String   @id @default(uuid())
  currencyId    String
  currency      Currency @relation(fields: [currencyId], references: [id])
  currencyCode  String
  oldRate       Float?
  newRate       Float
  effectiveFrom DateTime
  changedBy     String?
  changedDate   DateTime @default(now())

  @@index([currencyId])
  @@map("currency_rate_history")
}

enum BookingStatus {
  Won
  Booked
  OnTrip
  Completed
  Cancelled
}

enum BookingComponentType {
  Hotel
  Transfer
  Activity
  Visa
}

enum BookingComponentStatus {
  Pending
  Confirmed
  Cancelled
  Approved
  Rejected
}

enum BookingDocumentType {
  Passport
  Visa
  FlightTicket
  Insurance
}

model Booking {
  id                 String        @id @default(uuid())
  seq                Int           @unique @default(autoincrement())
  leadId             String
  lead               Lead          @relation(fields: [leadId], references: [id])
  quotationId        String?
  quotation          Quotation?    @relation(fields: [quotationId], references: [id])
  destinationId      String
  destination        Destination   @relation(fields: [destinationId], references: [id])
  travelDate         DateTime?
  bookingExecutiveId String?
  bookingExecutive   User?         @relation("BookingExecutive", fields: [bookingExecutiveId], references: [id])
  customerSupportId  String?
  customerSupport    User?         @relation("CustomerSupport", fields: [customerSupportId], references: [id])
  totalAmount        Int           @default(0)
  status             BookingStatus @default(Won)
  remarks            String?
  dmcName            String?
  dmcEmailSentDate   DateTime?
  dmcResponse        String?
  dmcRemarks         String?

  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  documents  BookingDocument[]
  components BookingComponent[]

  @@index([leadId])
  @@index([bookingExecutiveId])
  @@index([customerSupportId])
  @@map("bookings")
}

model BookingDocument {
  id           String              @id @default(uuid())
  bookingId    String
  booking      Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type         BookingDocumentType
  url          String
  uploadedDate DateTime            @default(now())

  @@unique([bookingId, type])
  @@map("booking_documents")
}

model BookingComponent {
  id        String                 @id @default(uuid())
  bookingId String
  booking   Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  component BookingComponentType
  detail    String                 @default("")
  status    BookingComponentStatus @default(Pending)
  sortOrder Int                    @default(0)

  @@index([bookingId])
  @@map("booking_components")
}
