// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Admin enums
enum Status {
  Active
  Inactive
}

enum OtpPurpose {
  Registration
  ForgotPassword
}

model Role {
  id   String @id @default(uuid())
  name String @unique // Admin | Employee | Customer

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model User {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  email           String    @unique
  phoneNumber     String?
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(false)
  lastLogin       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailOtps     EmailOtp[]
  refreshTokens RefreshToken[]
  assignedLeads Lead[]

  @@index([roleId])
  @@map("users")
}

model EmailOtp {
  id        String     @id @default(uuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  email     String
  otpHash   String
  purpose   OtpPurpose
  attempts  Int        @default(0)
  expiresAt DateTime
  isUsed    Boolean    @default(false)

  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("email_otps")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Destination {
  id              String   @id @default(uuid())
  name            String
  country         String
  state           String?
  city            String?
  slug            String   @unique
  shortDescription String
  fullDescription String
  thumbnailImage  String?
  bannerImage     String?
  isPopular       Boolean  @default(false)
  displayOrder    Int      @default(0)
  seoTitle        String?
  seoDescription  String?
  status          Status   @default(Active)
  isDomestic      Boolean  @default(false)

  // Audit
  createdBy       String?
  createdDate     DateTime @default(now())
  updatedBy       String?
  updatedDate     DateTime @updatedAt
  isDeleted       Boolean  @default(false)

  campaigns       Campaign[]
  leads           Lead[]
  quotations      Quotation[]

  @@map("destinations")
}

model Campaign {
  id                  String      @id @default(uuid())
  name                String
  destinationId       String
  destination         Destination @relation(fields: [destinationId], references: [id], onDelete: Restrict)
  packageType         String      @default("Standard")
  days                Int         @default(0)
  nights              Int         @default(0)
  startingPrice       Int         @default(0)
  offerPrice          Int?
  thumbnail           String?
  coverBanner         String?
  shortDescription    String      @default("")
  highlights          String[]    @default([])
  inclusions          String[]    @default([])
  exclusions          String[]    @default([])
  bestTimeToVisit     String?
  travelTypes         String[]    @default([])
  isFeatured          Boolean     @default(false)
  isRecentlyViewed    Boolean     @default(false)
  isHeroCampaign      Boolean     @default(false)
  viewDetailsRedirect String?
  slug                String      @unique
  seoTitle            String?
  seoDescription      String?
  status              Status      @default(Active)
  gallery             String[]    @default([])
  bookedByName        String?
  bookedByCity        String?
  bookedByAgo         String?
  activities          Json        @default("[]")
  inclusionsText      String      @default("")
  exclusionsText      String      @default("")
  packageCost         Int         @default(0)
  platformFee         Int         @default(0)
  gstPercent          Float       @default(5)
  marginPrice         Int         @default(0)
  insurancePrice      Int         @default(0)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  itineraries Itinerary[]
  hotels      Hotel[]
  transfers   Transfer[]
  quotations  Quotation[]

  @@index([destinationId])
  @@map("campaigns")
}

model Itinerary {
  id                 String   @id @default(uuid())
  packageId          String
  campaign           Campaign @relation(fields: [packageId], references: [id], onDelete: Cascade)
  title              String   @default("")
  overview           String   @default("")
  totalDays          Int      @default(0)
  days               Json     @default("[]")
  packageIncludes    String[] @default([])
  packageExcludes    String[] @default([])
  termsAndConditions String   @default("")
  cancellationPolicy String   @default("")
  faqs               Json     @default("[]")
  galleryImages      String[] @default([])
  mapLocation        String?
  customerNotes      String?
  ctaButtonText      String   @default("Send Enquiry")
  ctaRedirect        String   @default("/plan-trip")
  status             Status   @default(Active)
  isPublished        Boolean  @default(false)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([packageId])
  @@map("itineraries")
}

model Hotel {
  id        String   @id @default(uuid())
  packageId String
  campaign  Campaign @relation(fields: [packageId], references: [id], onDelete: Cascade)
  hotels    Json     @default("[]")
  status    Status   @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([packageId])
  @@map("hotels")
}

model Transfer {
  id        String   @id @default(uuid())
  packageId String
  campaign  Campaign @relation(fields: [packageId], references: [id], onDelete: Cascade)
  transfers Json     @default("[]")
  status    Status   @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([packageId])
  @@map("transfers")
}

model TransferType {
  id     String @id @default(uuid())
  name   String
  status Status @default(Active)

  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@map("transfer_types")
}

enum LeadSource {
  Website
  MetaAds
  GoogleAds
  SEO
  WhatsApp
  Referral
  Manual
}

enum LeadStatus {
  New
  Contacted
  FollowUp
  QuotationSent
  PaymentPending
  Won
  Lost
}

model Lead {
  id            String      @id @default(uuid())
  seq           Int         @unique @default(autoincrement())
  customerName  String
  mobile        String
  email         String?
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id])
  travelDate    DateTime?
  source        LeadSource
  adults        Int?
  children      Int?
  assignedToId  String?
  assignedTo    User?       @relation(fields: [assignedToId], references: [id])
  remarks       String?
  status        LeadStatus  @default(New)

  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  activities  LeadActivity[]
  quotations  Quotation[]

  @@index([destinationId])
  @@index([assignedToId])
  @@map("leads")
}

model LeadActivity {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  message     String
  createdDate DateTime @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

enum QuotationStatus {
  Draft
  Sent
  Accepted
  Rejected
  Expired
}

enum QuotationComponent {
  Hotel
  Transfer
  Activity
  Visa
  Insurance
  Flight
}

model Quotation {
  id            String          @id @default(uuid())
  seq           Int             @unique @default(autoincrement())
  leadId        String
  lead          Lead            @relation(fields: [leadId], references: [id])
  destinationId String
  destination   Destination     @relation(fields: [destinationId], references: [id])
  campaignId    String?
  campaign      Campaign?       @relation(fields: [campaignId], references: [id])
  marginPercent Float           @default(0)
  status        QuotationStatus @default(Draft)
  shareToken    String?         @unique

  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  items QuotationItem[]

  @@index([leadId])
  @@index([destinationId])
  @@map("quotations")
}

model QuotationItem {
  id          String             @id @default(uuid())
  quotationId String
  quotation   Quotation          @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  component   QuotationComponent
  detail      String             @default("")
  qty         Int                @default(1)
  cost        Int                @default(0)
  sortOrder   Int                @default(0)

  @@index([quotationId])
  @@map("quotation_items")
}
